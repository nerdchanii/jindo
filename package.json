{
  "name": "jindo",
  "version": "0.1.0",
  "description": "Ollama-based MCP agent with local models and CLI interface",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jindo": "dist/index.js"
  },
  "keywords": [
    "mcp",
    "ollama",
    "ai",
    "agent",
    "cli",
    "local-models"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.71.2",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "groq-sdk": "^0.37.0",
    "ink": "^6.6.0",
    "ink-text-input": "^6.0.0",
    "inquirer": "^9.2.0",
    "openai": "^6.16.0",
    "ora": "^8.0.0",
    "react": "^19.2.3",
    "yaml": "^2.3.0",
    "zod": "^3.22.0"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.0",
    "@types/node": "^20.0.0",
    "@types/react": "^19.2.9",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.56.0",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite-tsconfig-paths": "^4.3.0",
    "vitest": "^1.0.0"
  },
  "files": [
    "dist",
    "config",
    "README.md"
  ],
  "scripts": {
    "build": "tsc && cp -r src/prompts dist/",
    "dev": "tsx src/index.ts",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  }
}
